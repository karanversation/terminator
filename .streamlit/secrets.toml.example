# Copy this file to secrets.toml and fill in your values.
# secrets.toml is gitignored and never committed.

# Required for SBI password-protected XLSX statement parsing
SBI_XLSX_PASSWORD = "your_dob_or_account_password"

# Required for CAMS CAS PDF parsing (usually your PAN in uppercase)
CAMS_PDF_PASSWORD = "YOUR_PAN_UPPERCASE"

# Optional: enables AI-assisted categorisation on the Transactions page
OPENAI_API_KEY = "sk-..."
